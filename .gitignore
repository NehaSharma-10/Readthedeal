# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==================
# DEPENDENCIES
# ==================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==================
# TESTING
# ==================
/coverage
.nyc_output
*.lcov

# ==================
# NEXT.JS
# ==================
/.next/
/out/
*.prod.js

# ==================
# PRODUCTION & BUILD
# ==================
/build
/dist
*.tsbuildinfo

# ==================
# ENVIRONMENT & SECRETS
# ==================
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
!.env.local.example
!.env.example

# ==================
# IDE & EDITOR
# ==================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ==================
# DEBUG & LOGS
# ==================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log
logs/
*.log

# ==================
# SYSTEM FILES
# ==================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==================
# DEPLOYMENT
# ==================
.vercel
.netlify
.env.production
.now

# ==================
# NODE
# ==================
npm-shrinkwrap.json
package-lock.json (keep in git for consistency)

# ==================
# TYPESCRIPT
# ==================
next-env.d.ts
*.d.ts
!src/**/*.d.ts

# ==================
# CACHE & TEMP
# ==================
.cache/
*.cache
tmp/
temp/
.turbo/
.eslintcache
.stylelintcache

# ==================
# OPTIONAL NPM CACHE DIRECTORY
# ==================
.npm

# ==================
# OPTIONAL ESLINT CACHE
# ==================
.eslintcache

# ==================
# OPTIONAL NEXT.JS CACHE
# ==================
.next/cache/

# ==================
# OPTIONAL STORYBOOK CACHE
# ==================
storybook-static/

# ==================
# OS GENERATED FILES
# ==================
.Thumbs.db
.Thumbs.db:encryptable

# ==================
# MISC
# ==================
*.pem
dist/
.idea
.env.production
.vscode/launch.json
.vscode/extensions.json
.history/
.PHONY
.env.vault

